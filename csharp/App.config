<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="DefaultCipher" value="AES-256-GCM"/>
    <add key="DefaultHash" value="SHA-256"/>
    <add key="Signature" value="ECDSA"/>
    <add key="Kem" value="ML-KEM-768"/>
    <add key="LegacyMD5" value="false"/>
    <add key="LegacyDES" value="false"/>
  </appSettings>
</configuration>
